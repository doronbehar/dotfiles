IMAPAccount gmail
Host imap.gmail.com
User doron.behar@gmail.com
PassCmd "secret-tool lookup user doron.behar@gmail.com"
TLSType IMAPS
CertificateFile /etc/ssl/certs/ca-certificates.crt

IMAPStore gmail-remote
Account gmail

# Gmail Store for everything except inbox (Limited to 5M)
MaildirStore gmail-local-limited
Path ~/.local/share/mail/gmail/
Inbox ~/.local/share/mail/gmail/INBOX
Trash [Gmail]/Trash
SubFolders Verbatim
MaxSize 5M

# Gmail Store for INBOX only (Unlimited size)
MaildirStore gmail-local-unlimited
Path ~/.local/share/mail/gmail/
Inbox ~/.local/share/mail/gmail/INBOX
Trash [Gmail]/Trash
SubFolders Verbatim
MaxSize 0

# Gmail Channel 1: Dedicated to INBOX (Points to the unlimited store)
Channel gmail-inbox
Far :gmail-remote:
Near :gmail-local-unlimited:
Patterns INBOX
Expunge Near
MaxMessages 180
ExpireUnread yes
Create Both

# Gmail Channel 2: All other folders (Points to the limited store)
Channel gmail-others
Far :gmail-remote:
Near :gmail-local-limited:
Patterns Lists/*
Patterns [Gmail]/Trash
Patterns orders/*
Patterns Keep
Patterns Jobs
Patterns [Gmail]/Sent*
Patterns [Gmail]/Drafts
Expunge Near
# to make it suitable for mailing lists
MaxMessages 180
ExpireUnread yes
Create Both

IMAPAccount gandi
Host mail.gandi.net
User me@doronbehar.com
PassCmd "secret-tool lookup user me@doronbehar.com"
TLSType IMAPS
CertificateFile /etc/ssl/certs/ca-certificates.crt

IMAPStore gandi-remote
Account gandi

MaildirStore gandi-local
# The trailing "/" is important
Path ~/.local/share/mail/gandi/
Inbox ~/.local/share/mail/gandi/INBOX
Trash Trash
SubFolders Verbatim

Channel gandi
Far :gandi-remote:
Near :gandi-local:
Patterns INBOX
Patterns Sent
Patterns Drafts
Patterns Trash
Patterns Archive
# Automatically create missing mailboxes, both locally and on the server
Create Both
# Save the synchronization state files in the relevant directory
SyncState *
Expunge Near
